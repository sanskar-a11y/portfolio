{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Push to GitHub",
      "type": "shell",
      "command": "git add . && git commit -m 'update: ${input:commitMessage}' && git push origin main",
      "inputs": [
        {
          "id": "commitMessage",
          "type": "promptString",
          "description": "Commit message",
          "default": "site update"
        }
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    }
  ]
}
